<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme (used by Compose, minimal) -->
    <style name="Theme.VedicAstrology" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.VedicAstrology.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF1A1030</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.VedicAstrology</item>
    </style>

</resources>
